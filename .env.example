
POSTGRES_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=5

SECRET_KEY=change-me-to-a-32+-character-random-string
SUPERADMIN_EMAIL=your@gmail.com
SUPERADMIN_PASSWORD=yourpassword

# ── One-time platform tenant seed (optional) ──────────────────────────────────
# Used by: auth-engine-data all  |  auth-engine-data platform-config
# PASSWORD_MIN_LENGTH=8
# PASSWORD_REQUIRE_UPPERCASE=True
# PASSWORD_REQUIRE_LOWERCASE=True
# PASSWORD_REQUIRE_DIGIT=True
# PASSWORD_REQUIRE_SPECIAL=True
