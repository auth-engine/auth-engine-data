# auth-engine-data reads configuration through the auth_engine settings, which
# load a .env.local file from the current working directory. Copy this file to
# .env.local and fill in the values for the target environment/database.

# ── Required by auth_engine settings (validated on import) ──────────────────
SECRET_KEY=change-me-to-a-32+-character-random-string
JWT_SECRET_KEY=change-me-to-a-32+-character-random-string
POSTGRES_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
MONGODB_URL=mongodb://localhost:27017
REDIS_URL=redis://localhost:6379

# ── Super admin to bootstrap ────────────────────────────────────────────────
SUPERADMIN_EMAIL=admin@authengine.org
SUPERADMIN_PASSWORD=ChangeThisStrongPassword123!
